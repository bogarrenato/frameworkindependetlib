{
  "name": "@fuggetlenfe/react-showcase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && SSR_BRAND=brand-2 SSR_THEME=light node scripts/prerender.mjs",
    "build:spa": "tsc -b && vite build",
    "prerender": "SSR_BRAND=brand-2 SSR_THEME=light node scripts/prerender.mjs",
    "build-storybook": "storybook build -c .storybook -o ../../storybook-static/react",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6007 -c .storybook --ci",
    "test": "vitest run"
  },
  "dependencies": {
    "@fuggetlenfe/brand-styles": "workspace:*",
    "@fuggetlenfe/react-wrapper": "workspace:*",
    "@fuggetlenfe/tokens": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "storybook": "^10.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.0.8"
  }
}
