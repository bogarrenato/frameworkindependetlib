            "description": "",
            "rawdescription": "\n",
            "type": "component",
            "sourceCode": "import { Component, signal } from '@angular/core';\nimport { FfButton } from '@fuggetlenfe/angular-wrapper';\n\n@Component({\n  selector: 'app-root',\n  imports: [FfButton],\n  templateUrl: './app.html',\n  styleUrl: './app.css'\n})\nexport class App {\n  readonly theme = signal<'light' | 'dark'>('light');\n\n  setTheme(theme: 'light' | 'dark') {\n    this.theme.set(theme);\n  }\n}\n",
            "styleUrl": "./app.css",
            "assetsDirs": [],
            "styleUrlsData": "",
            "stylesData": "",
            "extends": [],
            "templateData": "<main class=\"consumer-shell\" data-brand=\"brand-1\" [attr.data-theme]=\"theme()\">\n  <section class=\"hero-card\">\n    <p class=\"eyebrow\">Angular app · external CSS brand pack</p>\n    <h1>Angular consumes only wrapper logic, then Brand 1 arrives from CSS.</h1>\n    <p class=\"body-copy\">\n      This application imports the Angular wrapper plus the Brand 1 light and dark packs. The\n      component library itself stays visually neutral until the external stylesheet is present.\n    </p>\n\n    <div class=\"theme-bar\" role=\"group\" aria-label=\"Theme switcher\">\n      <p class=\"theme-label\">Theme pack</p>\n      <div class=\"theme-actions\">\n        <button type=\"button\" class=\"theme-button\" [attr.data-selected]=\"theme() === 'light'\" (click)=\"setTheme('light')\">\n          Light\n        </button>\n        <button type=\"button\" class=\"theme-button\" [attr.data-selected]=\"theme() === 'dark'\" (click)=\"setTheme('dark')\">\n          Dark\n        </button>\n      </div>\n    </div>\n\n    <div class=\"button-row\">\n      <ff-button class=\"brand-host\">Brand 1 default</ff-button>\n      <ff-button class=\"pill-host\">Class-based override</ff-button>\n      <ff-button\n        [style.--ff-button-padding-inline]=\"'0.95rem'\"\n        [style.--ff-button-padding-block]=\"'0.48rem'\"\n        [style.--ff-button-radius]=\"'4px'\"\n      >\n        Inline token tweak\n      </ff-button>\n    </div>\n  </section>\n\n  <section class=\"info-grid\">\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">Consumer imports</p>\n      <div class=\"detail-block\" aria-label=\"Consumer imports\">\n        <div class=\"detail-line\">import &#123; FfButton &#125; from '@fuggetlenfe/angular-wrapper'</div>\n        <div class=\"detail-line\">@import '@fuggetlenfe/tokens/contract.css';</div>\n        <div class=\"detail-line\">@import '@fuggetlenfe/brand-styles/brand-1-light.css';</div>\n        <div class=\"detail-line\">@import '@fuggetlenfe/brand-styles/brand-1-dark.css';</div>\n        <div class=\"detail-line detail-line--gap\">&lt;main data-brand=\"brand-1\" [attr.data-theme]=\"theme()\"&gt;</div>\n        <div class=\"detail-line\">&nbsp;&nbsp;&lt;ff-button&gt;&lt;/ff-button&gt;</div>\n        <div class=\"detail-line\">&lt;/main&gt;</div>\n      </div>\n    </article>\n\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">Theme behavior</p>\n      <div class=\"detail-block\" aria-label=\"Theme behavior\">\n        <div class=\"detail-line\">The shell flips between light and dark.</div>\n        <div class=\"detail-line\">The button keeps the same logic API in both modes.</div>\n        <div class=\"detail-line\">Brand 1 colors come entirely from the imported CSS pack.</div>\n      </div>\n    </article>\n\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">What proves the separation</p>\n      <div class=\"proof-list\">\n        <div class=\"proof-item\">The Angular wrapper provides framework integration only.</div>\n        <div class=\"proof-item\">The imported CSS library gives the component its brand and surface tokens.</div>\n        <div class=\"proof-item\">The same wrapper logic swaps between light and dark with CSS alone.</div>\n        <div class=\"proof-item\">Host classes and per-instance CSS properties still tailor the component locally.</div>\n      </div>\n    </article>\n  </section>\n</main>\n"
        }
    ],
