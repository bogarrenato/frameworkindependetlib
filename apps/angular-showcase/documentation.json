            "description": "",
            "rawdescription": "\n",
            "type": "component",
            "sourceCode": "import { Component, signal } from '@angular/core';\nimport { FfButton } from '@fuggetlenfe/angular-wrapper';\n\ntype ThemeMode = 'light' | 'dark';\n\ntype ThemeOption = {\n  label: string;\n  value: ThemeMode;\n};\n\n@Component({\n  selector: 'app-root',\n  imports: [FfButton],\n  templateUrl: './app.html',\n  styleUrl: './app.css',\n})\nexport class BrandOneShowcaseAppComponent {\n  readonly activeTheme = signal<ThemeMode>('light');\n  readonly themeOptions: readonly ThemeOption[] = [\n    { label: 'Light', value: 'light' },\n    { label: 'Dark', value: 'dark' },\n  ];\n  readonly inlineTokenStyle = {\n    paddingInline: '0.95rem',\n    paddingBlock: '0.48rem',\n    radius: '4px',\n  };\n\n  setTheme(selectedTheme: ThemeMode) {\n    this.activeTheme.set(selectedTheme);\n  }\n}\n",
            "styleUrl": "./app.css",
            "assetsDirs": [],
            "styleUrlsData": "",
            "stylesData": "",
            "extends": [],
            "templateData": "<main class=\"consumer-shell\" data-brand=\"brand-1\" [attr.data-theme]=\"activeTheme()\">\n  <section class=\"hero-card\">\n    <p class=\"eyebrow\">Angular app · external CSS brand pack</p>\n    <h1>Angular consumes only wrapper logic, then Brand 1 arrives from CSS.</h1>\n    <p class=\"body-copy\">\n      This application imports the Angular wrapper plus the Brand 1 light and dark packs. The\n      component library itself stays visually neutral until the external stylesheet is present.\n    </p>\n\n    <div class=\"theme-bar\" role=\"group\" aria-label=\"Theme switcher\">\n      <p class=\"theme-label\">Theme pack</p>\n      <div class=\"theme-actions\">\n        @for (themeOption of themeOptions; track themeOption.value) {\n          <button\n            type=\"button\"\n            class=\"theme-button\"\n            [attr.data-selected]=\"activeTheme() === themeOption.value\"\n            (click)=\"setTheme(themeOption.value)\"\n          >\n            {{ themeOption.label }}\n          </button>\n        }\n      </div>\n    </div>\n\n    <div class=\"button-row\">\n      <ff-button class=\"brand-host\">Brand 1 default</ff-button>\n      <ff-button class=\"pill-host\">Class-based override</ff-button>\n      <ff-button\n        [style.--ff-button-padding-inline]=\"inlineTokenStyle.paddingInline\"\n        [style.--ff-button-padding-block]=\"inlineTokenStyle.paddingBlock\"\n        [style.--ff-button-radius]=\"inlineTokenStyle.radius\"\n      >\n        Inline token tweak\n      </ff-button>\n    </div>\n  </section>\n\n  <section class=\"info-grid\">\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">Consumer imports</p>\n      <div class=\"detail-block\" aria-label=\"Consumer imports\">\n        <div class=\"detail-line\">Import the Angular wrapper package.</div>\n        <div class=\"detail-line\">Import the shared token contract.</div>\n        <div class=\"detail-line\">Import the Brand 1 light stylesheet.</div>\n        <div class=\"detail-line\">Import the Brand 1 dark stylesheet.</div>\n        <div class=\"detail-line detail-line--gap\">\n          Set data-brand=\"brand-1\" and the active theme on the outer shell.\n        </div>\n        <div class=\"detail-line\">Render the same ff-button logic inside that shell.</div>\n      </div>\n    </article>\n\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">Theme behavior</p>\n      <div class=\"detail-block\" aria-label=\"Theme behavior\">\n        <div class=\"detail-line\">The shell flips between light and dark.</div>\n        <div class=\"detail-line\">The button keeps the same logic API in both modes.</div>\n        <div class=\"detail-line\">Brand 1 colors come entirely from the imported CSS pack.</div>\n        <div class=\"detail-line\">The current PoC deliberately ships only the primitive represented in Figma: the button.</div>\n      </div>\n    </article>\n\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">What proves the separation</p>\n      <div class=\"proof-list\">\n        <div class=\"proof-item\">The Angular wrapper provides framework integration only.</div>\n        <div class=\"proof-item\">\n          The imported CSS library gives the primitives their brand and surface tokens.\n        </div>\n        <div class=\"proof-item\">\n          The same wrapper logic swaps between light and dark with CSS alone.\n        </div>\n        <div class=\"proof-item\">\n          Host classes and per-instance CSS properties still tailor the component locally.\n        </div>\n        <div class=\"proof-item\">\n          Removing a non-Figma primitive leaves the Angular bridge untouched for the shipped button.\n        </div>\n      </div>\n    </article>\n  </section>\n</main>\n"
        }
    ],
