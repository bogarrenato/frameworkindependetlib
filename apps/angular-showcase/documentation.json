                "type": "StorybookConfig",
                "defaultValue": "{\n  stories: ['../src/**/*.stories.@(ts|mdx)'],\n  addons: ['@storybook/addon-docs', '@storybook/addon-a11y'],\n  framework: {\n    name: '@storybook/angular',\n    options: {}\n  },\n  docs: {\n    autodocs: 'tag'\n  }\n}"
