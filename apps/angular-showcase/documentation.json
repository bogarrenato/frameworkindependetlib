            "description": "",
            "rawdescription": "\n",
            "type": "component",
            "sourceCode": "import { Component, signal } from '@angular/core';\nimport { FfButton } from '@fuggetlenfe/angular-wrapper';\n\n@Component({\n  selector: 'app-root',\n  imports: [FfButton],\n  templateUrl: './app.html',\n  styleUrl: './app.css'\n})\nexport class App {\n  readonly theme = signal<'light' | 'dark'>('light');\n\n  setTheme(theme: 'light' | 'dark') {\n    this.theme.set(theme);\n  }\n}\n",
            "styleUrl": "./app.css",
            "assetsDirs": [],
            "styleUrlsData": "",
            "stylesData": "",
            "extends": [],
            "templateData": "<main class=\"consumer-shell\" data-brand=\"brand-1\" [attr.data-theme]=\"theme()\">\n  <section class=\"hero-card\">\n    <p class=\"eyebrow\">Angular app · external CSS brand pack</p>\n    <h1>Angular consumes only wrapper logic, then Brand 1 arrives from CSS.</h1>\n    <p class=\"body-copy\">\n      This application imports <code>@fuggetlenfe/angular-wrapper</code>, plus\n      <code>@fuggetlenfe/tokens/contract.css</code> and\n      <code>@fuggetlenfe/brand-styles/brand-1-light.css</code> together with\n      <code>@fuggetlenfe/brand-styles/brand-1-dark.css</code>. The component library itself stays\n      visually neutral until the external stylesheet is present.\n    </p>\n\n    <div class=\"theme-bar\" role=\"group\" aria-label=\"Theme switcher\">\n      <p class=\"theme-label\">Theme pack</p>\n      <div class=\"theme-actions\">\n        <button type=\"button\" class=\"theme-button\" [attr.data-selected]=\"theme() === 'light'\" (click)=\"setTheme('light')\">\n          Light\n        </button>\n        <button type=\"button\" class=\"theme-button\" [attr.data-selected]=\"theme() === 'dark'\" (click)=\"setTheme('dark')\">\n          Dark\n        </button>\n      </div>\n    </div>\n\n    <div class=\"button-row\">\n      <ff-button brand=\"brand-1\" class=\"brand-host\">Brand 1 default</ff-button>\n      <ff-button brand=\"brand-1\" class=\"pill-host\">Class-based override</ff-button>\n      <ff-button\n        brand=\"brand-1\"\n        class=\"inline-host\"\n        [style.--ff-button-padding-inline]=\"'1.5rem'\"\n        [style.--ff-button-padding-block]=\"'0.7rem'\"\n      >\n        Inline CSS property\n      </ff-button>\n    </div>\n  </section>\n\n  <section class=\"info-grid\">\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">Consumer imports</p>\n      <pre>import &#123; FfButton &#125; from '@fuggetlenfe/angular-wrapper'\n@import '@fuggetlenfe/tokens/contract.css';\n@import '@fuggetlenfe/brand-styles/brand-1-light.css';\n@import '@fuggetlenfe/brand-styles/brand-1-dark.css';</pre>\n    </article>\n\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">Theme behavior</p>\n      <pre>[attr.data-theme]=\\\"theme()\\\"\ndata-theme=\\\"{{ theme() }}\\\"</pre>\n    </article>\n\n    <article class=\"info-card\">\n      <p class=\"eyebrow\">What proves the separation</p>\n      <ul>\n        <li>The Angular wrapper provides framework integration only.</li>\n        <li>The imported CSS library gives the component its brand and surface tokens.</li>\n        <li>The same wrapper logic swaps between light and dark with CSS alone.</li>\n        <li>Host classes and per-instance CSS properties still tailor the component locally.</li>\n      </ul>\n    </article>\n  </section>\n</main>\n"
        }
    ],
